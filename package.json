{
	"name": "convex-svelte",
	"author": "Convex, Inc. <no-reply@convex.dev>",
	"contributors": [
		"Convex, Inc. <no-reply@convex.dev>",
		"Micha Mailaender"
	],
	"version": "0.19.0",
	"license": "Apache-2.0",
	"homepage": "https://convex.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/get-convex/convex-svelte.git"
	},
	"scripts": {
		"dev": "concurrently --kill-others --prefix-colors blue,yellow --names 'svelte,convex' 'pnpm dev:client' 'pnpm dev:server'",
		"dev:client": "vite dev --open",
		"dev:server": "convex dev",
		"dev:init": "convex dev --until-success --run messages:seed",
		"build": "vite build && pnpm package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "pnpm package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test": "pnpm test:unit && pnpm test:e2e",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish && git push --follow-tags"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./sveltekit": {
			"types": "./dist/sveltekit/index.d.ts",
			"svelte": "./dist/sveltekit/index.js",
			"import": "./dist/sveltekit/index.js",
			"default": "./dist/sveltekit/index.js"
		},
		"./sveltekit/server": {
			"types": "./dist/sveltekit/server-token.d.ts",
			"import": "./dist/sveltekit/server-token.js",
			"default": "./dist/sveltekit/server-token.js"
		}
	},
	"peerDependencies": {
		"convex": ">1.10.0",
		"svelte": ">=5.36.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@convex-dev/eslint-plugin": "^2.0.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/eslint": "^9.6.1",
		"@types/node": "^22.19.19",
		"concurrently": "^9.2.1",
		"convex": "^1.38.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"publint": "^0.3.21",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"esm-env": "^1.2.2",
		"runed": "^0.37.1"
	}
}
